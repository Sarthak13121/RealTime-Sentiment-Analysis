# News API Key (Get one from https://newsapi.org/)
NEWS_API_KEY=your_news_api_key_here

# Location/IP Info API Key (Optional fallback, if used)
LOCATION_API_KEY=your_location_api_key_here

# Flask Secret Key for session signing
FLASK_SECRET_KEY=your_random_secret_string_here

# Flask Environment configuration (development or production)
FLASK_ENV=development
